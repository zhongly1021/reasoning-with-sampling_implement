   "source": [
    "import json\n",
    "from pathlib import Path\n",
    "from typing import Any, Dict, List, Optional\n",
    "\n",
    "import pandas as pd\n",
    "\n",
    "\n",
    "def _clean_columns(df: pd.DataFrame) -> pd.DataFrame:\n",
    "    df = df.copy()\n",
    "    df.columns = [str(c).replace(\"\\ufeff\", \"\").strip().upper() for c in df.columns]\n",
    "    return df\n",
    "\n",
    "\n",
    "def _try_read_csv(path_obj: Path) -> pd.DataFrame:\n",
    "    encodings = [\"utf-8-sig\", \"utf-8\", \"cp949\", \"euc-kr\", \"latin1\"]\n",
    "    last_err = None\n",
    "    for enc in encodings:\n",
    "        try:\n",
    "            return pd.read_csv(path_obj, encoding=enc, low_memory=False)\n",
    "        except Exception as e:\n",
    "            last_err = e\n",
    "    raise last_err\n",
    "\n",
    "\n",
    "def read_table(path: str) -> pd.DataFrame:\n",
    "    path_obj = Path(path)\n",
    "    suffix = path_obj.suffix.lower()\n",
    "\n",
    "    if suffix == \".csv\":\n",
    "        df = _try_read_csv(path_obj)\n",
    "    elif suffix in [\".xlsx\", \".xls\"]:\n",
    "        df = pd.read_excel(path_obj)\n",
    "    else:\n",
    "        raise ValueError(f\"Unsupported file type: {suffix}. Only csv/xlsx/xls are supported.\")\n",
    "\n",
    "    df = _clean_columns(df)\n",
    "\n",
    "    for col in [\"ORIGIN\", \"DESTIN\"]:\n",
    "        if col in df.columns:\n",
    "            df[col] = df[col].apply(lambda x: None if pd.isna(x) else str(x).strip())\n",
    "\n",
    "    return df\n",
    "\n",
    "\n",
    "def pick_one_hot_int(row: pd.Series, cols: List[str], default: Optional[int] = None) -> Optional[int]:\n",
    "    for i, col in enumerate(cols, start=1):\n",
    "        val = row.get(col, 0)\n",
    "        if pd.notna(val):\n",
    "            try:\n",
    "                if int(float(val)) == 1:\n",
    "                    return i\n",
    "            except Exception:\n",
    "                pass\n",
    "    return default\n",
    "\n",
    "\n",
    "def derive_age(row: pd.Series) -> Optional[int]:\n",
    "    # 1:<20, 2:20-39, 3:40-59, 4:60+\n",
    "    return pick_one_hot_int(row, [\"AGE01\", \"AGE23\", \"AGE45\", \"AGE6\"], default=None)\n",
    "\n",
    "\n",
    "def derive_income_level(row: pd.Series) -> Optional[int]:\n",
    "    # 1:<1400, 2:1400~3500, 3:3500~7000\n",
    "    return pick_one_hot_int(row, [\"INC1\", \"INC2\", \"INC3\"], default=None)\n",
    "\n",
    "\n",
    "def to_int(x: Any) -> Optional[int]:\n",
    "    if pd.isna(x):\n",
    "        return None\n",
    "    return int(float(x))\n",
    "\n",
    "\n",
    "def to_float(x: Any) -> Optional[float]:\n",
    "    if pd.isna(x):\n",
    "        return None\n",
    "    return float(x)\n",
    "\n",
    "\n",
    "def aggregate_choice_group(order_value: Any, g: pd.DataFrame) -> Dict[str, Any]:\n",
    "    g = g.copy()\n",
    "\n",
    "    chosen = g.loc[pd.to_numeric(g[\"MCHOICE\"], errors=\"coerce\") == 1, \"MODEALT\"]\n",
    "    chosen_mode = chosen.iloc[0] if len(chosen) > 0 else None\n",
    "\n",
    "    base = g.iloc[0]\n",
    "\n",
    "    rec: Dict[str, Any] = {\n",
    "        \"ORDER\": to_int(order_value),\n",
    "        \"TP_ORDER\": to_int(base.get(\"TP_ORDER\")),\n",
    "        \"ORIGIN\": None if pd.isna(base.get(\"ORIGIN\")) else str(base.get(\"ORIGIN\")),\n",
    "        \"DESTINATION\": None if pd.isna(base.get(\"DESTIN\")) else str(base.get(\"DESTIN\")),\n",
    "        \"TPN\": to_int(base.get(\"TPN\")),\n",
    "        \"DT\": to_int(base.get(\"DT\")),\n",
    "        \"MODEALT\": [None if pd.isna(x) else str(x) for x in g[\"MODEALT\"].tolist()],\n",
    "        \"STT\": [to_float(x) for x in g[\"STT\"].tolist()],\n",
    "        \"STD\": [to_float(x) for x in g[\"STD\"].tolist()],\n",
    "        \"STC\": [to_float(x) for x in g[\"STC\"].tolist()],\n",
    "        \"INCOMELEVEL\": derive_income_level(base),\n",
    "        \"SEX\": to_int(base.get(\"MALE\")),\n",
    "        \"AGE\": derive_age(base),\n",
    "        \"NSUB\": to_float(base.get(\"NSUB\")),\n",
    "        \"NBUS\": to_float(base.get(\"NBUS\")),\n",
    "        \"NPARK\": to_float(base.get(\"NPARK\")),\n",
    "        \"NBIKE\": to_float(base.get(\"NBIKE\")),\n",
    "        \"NBIKEC\": to_float(base.get(\"NBIKEC\")),\n",
    "        \"CHOSENMODE\": chosen_mode,\n",
    "    }\n",
    "\n",
    "    if \"PREMOI\" in base.index:\n",
    "        rec[\"PREMOI\"] = to_int(base.get(\"PREMOI\"))\n",
    "    else:\n",
    "        rec[\"PREMOI\"] = None\n",
    "\n",
    "    return rec\n",
    "\n",
    "\n",
    "def aggregate_trips(df: pd.DataFrame) -> pd.DataFrame:\n",
    "    records = []\n",
    "    for order_value, g in df.groupby(\"ORDER\", sort=False):\n",
    "        records.append(aggregate_choice_group(order_value, g))\n",
    "    trips = pd.DataFrame(records)\n",
    "    return trips\n",
    "\n",
    "\n",
    "def assign_person_id(trips: pd.DataFrame) -> pd.DataFrame:\n",
    "    trips = trips.copy()\n",
    "\n",
    "    if \"ORDER\" in trips.columns:\n",
    "        trips[\"_order_sort\"] = pd.to_numeric(trips[\"ORDER\"], errors=\"coerce\")\n",
    "        trips = trips.sort_values([\"_order_sort\", \"TP_ORDER\"], kind=\"stable\").reset_index(drop=True)\n",
    "    else:\n",
    "        trips = trips.sort_values([\"TP_ORDER\"], kind=\"stable\").reset_index(drop=True)\n",
    "\n",
    "    current_id = 1\n",
    "    prev_tp = None\n",
    "    ids = []\n",
    "\n",
    "    for i, row in trips.iterrows():\n",
    "        tp = row[\"TP_ORDER\"]\n",
    "        premoi = row.get(\"PREMOI\")\n",
    "\n",
    "        if i == 0:\n",
    "            ids.append(current_id)\n",
    "            prev_tp = tp\n",
    "            continue\n",
    "\n",
    "        if premoi == 1:\n",
    "            current_id += 1\n",
    "        else:\n",
    "            if prev_tp is not None and tp is not None and (tp == 1 or tp <= prev_tp):\n",
    "                current_id += 1\n",
    "\n",
    "        ids.append(current_id)\n",
    "        prev_tp = tp\n",
    "\n",
    "    trips.insert(0, \"ID\", ids)\n",
    "    trips = trips.drop(columns=[\"_order_sort\"], errors=\"ignore\")\n",
    "    return trips\n",
    "\n",
    "\n",
    "def add_premot(trips: pd.DataFrame) -> pd.DataFrame:\n",
    "    trips = trips.copy()\n",
    "    trips[\"_order_sort\"] = pd.to_numeric(trips[\"ORDER\"], errors=\"coerce\")\n",
    "    trips = trips.sort_values([\"ID\", \"TP_ORDER\", \"_order_sort\"], kind=\"stable\").reset_index(drop=True)\n",
    "\n",
    "    premot_values = []\n",
    "\n",
    "    for _, g in trips.groupby(\"ID\", sort=False):\n",
    "        g = g.sort_values([\"TP_ORDER\", \"_order_sort\"], kind=\"stable\")\n",
    "        prev_mode = None\n",
    "        prev_tpn = None\n",
    "\n",
    "        for i, (_, row) in enumerate(g.iterrows()):\n",
    "            if i == 0:\n",
    "                premot_values.append(0)\n",
    "            else:\n",
    "                premot_values.append([prev_mode, to_int(prev_tpn)])\n",
    "\n",
    "            prev_mode = row[\"CHOSENMODE\"]\n",
    "            prev_tpn = row[\"TPN\"]\n",
    "\n",
    "    trips[\"PREMOT\"] = premot_values\n",
    "    trips = trips.drop(columns=[\"_order_sort\"], errors=\"ignore\")\n",
    "    return trips\n",
    "\n",
    "\n",
    "def json_serialize_if_needed(x: Any) -> Any:\n",
    "    if isinstance(x, (list, dict)):\n",
    "        return json.dumps(x, ensure_ascii=False)\n",
    "    return x\n",
    "\n",
    "\n",
    "def process_file(input_path: str, output_path: str) -> pd.DataFrame:\n",
    "    df = read_table(input_path)\n",
    "\n",
    "    required_cols = [\n",
    "        \"ORDER\", \"MCHOICE\", \"MODEALT\", \"TP_ORDER\", \"ORIGIN\", \"DESTIN\", \"TPN\", \"DT\",\n",
    "        \"STT\", \"STD\", \"STC\", \"INC1\", \"INC2\", \"INC3\", \"MALE\",\n",
    "        \"AGE01\", \"AGE23\", \"AGE45\", \"AGE6\", \"NSUB\", \"NBUS\", \"NPARK\", \"NBIKE\", \"NBIKEC\"\n",
    "    ]\n",
    "    missing = [c for c in required_cols if c not in df.columns]\n",
    "    if missing:\n",
    "        raise ValueError(f\"Missing required columns: {missing}\")\n",
    "\n",
    "    trips = aggregate_trips(df)\n",
    "    trips = assign_person_id(trips)\n",
    "    trips = add_premot(trips)\n",
    "\n",
    "    final_cols = [\n",
    "        \"ID\", \"ORDER\", \"TP_ORDER\", \"ORIGIN\", \"DESTINATION\", \"TPN\", \"DT\",\n",
    "        \"MODEALT\", \"STT\", \"STD\", \"STC\",\n",
    "        \"INCOMELEVEL\", \"SEX\", \"AGE\",\n",
    "        \"NSUB\", \"NBUS\", \"NPARK\", \"NBIKE\", \"NBIKEC\",\n",
    "        \"PREMOT\", \"CHOSENMODE\"\n",
    "    ]\n",
    "    trips = trips[final_cols].rename(columns={\n",
    "        \"TP_ORDER\": \"TP_order\",\n",
    "        \"MODEALT\": \"ModeAlt\",\n",
    "        \"INCOMELEVEL\": \"IncomeLevel\",\n",
    "        \"SEX\": \"sex\",\n",
    "        \"CHOSENMODE\": \"ChosenMode\",\n",
    "    })\n",
    "\n",
    "    for col in [\"ModeAlt\", \"STT\", \"STD\", \"STC\", \"PREMOT\"]:\n",
    "        trips[col] = trips[col].apply(json_serialize_if_needed)\n",
    "\n",
    "    trips.to_csv(output_path, index=False, encoding=\"utf-8-sig\")\n",
    "    return trips"
   ]
  },
